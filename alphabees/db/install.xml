<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="blocks/alphabees/db" VERSION="20260504" COMMENT="block_alphabees DB schema"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="block_alphabees_nonces" COMMENT="Replay-protection nonces for inbound signed requests.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="nonce" TYPE="char" LENGTH="64" NOTNULL="true"/>
        <FIELD NAME="expiresat" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="nonce_uniq" UNIQUE="true" FIELDS="nonce"/>
        <INDEX NAME="expiresat_idx" UNIQUE="false" FIELDS="expiresat"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="block_alphabees_retryqueue" COMMENT="Retry queue for outbound HTTP that failed transiently.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="endpoint" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="method" TYPE="char" LENGTH="8" NOTNULL="true" DEFAULT="POST"/>
        <FIELD NAME="payload" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="attempts" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="nextattempt" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="lasterror" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="nextattempt_idx" UNIQUE="false" FIELDS="nextattempt"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
